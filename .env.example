# --- MANDATORY CREDENTIALS ---

# GitHub Personal Access Token (PAT) 
# Needs: 'repo' scope to create repositories
GITHUB_TOKEN=your_github_token_here

# Dokploy API Access
DOKPLOY_API_URL=https://your-dokploy-domain.com/api
DOKPLOY_API_KEY=your_dokploy_api_key_here

# --- OPTIONAL: FOR AUTOMATIC DNS (HOSTINGER) ---

# Hostinger API Token
# Get it from hPanel -> Advanced -> API
HOSTINGER_API_TOKEN=your_hostinger_token_here
