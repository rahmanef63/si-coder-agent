# --- MANDATORY CREDENTIALS ---

# GitHub Personal Access Token (PAT)
# Scopes: 'repo' (full)
# Generate: https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_token_here

# Dokploy API access
# x-api-key header (NOT Bearer)
DOKPLOY_API_URL=https://your-dokploy-domain.com/api
DOKPLOY_API_KEY=your_dokploy_api_key_here

# --- OPTIONAL: DNS AUTOMATION ---

# Hostinger DNS — auto adds A records for main domain + api-/dash-/site- Convex subdomains.
# Get it from hPanel -> Advanced -> API.
HOSTINGER_API_TOKEN=your_hostinger_token_here

# Cloudflare (future, when /sc-cf ships)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# --- OPTIONAL: PRE-EXISTING CONVEX BACKEND (PLACEHOLDERS ONLY) ---
# Normally these are generated and saved automatically by sc-convex / sc-all.
# Only set these if you want to re-use a backend you deployed manually.

CONVEX_SELF_HOSTED_URL=https://<convex-api-domain>
CONVEX_SELF_HOSTED_ADMIN_KEY=<convex_admin_key>
NEXT_PUBLIC_CONVEX_URL=https://<convex-api-domain>
NEXT_PUBLIC_CONVEX_SITE_URL=https://<convex-site-domain>

# --- OPTIONAL: CLERK (ONLY if your app explicitly uses Clerk) ---
# By default sc-* uses @convex-dev/auth. Use Clerk MCP for Clerk-specific projects.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_<clerk_publishable_key>
CLERK_SECRET_KEY=sk_live_<clerk_secret_key>
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://<clerk-issuer-domain>
