# --- MANDATORY CREDENTIALS ---

# GitHub Personal Access Token (PAT)
# Scopes: 'repo' (full).  Fine-grained works too (Administration:write + Contents:write).
# Get it: https://github.com/settings/tokens/new   (shown once — copy immediately)
GITHUB_TOKEN=your_github_token_here
# GH_OWNER — GitHub owner for /sc-git ops. Defaults to your authed `gh` user; set to override.
# Push is over SSH — ensure `ssh -T git@github.com` works (add a key: https://github.com/settings/ssh/new).
# GH_OWNER=your_github_username

# Dokploy API access
# x-api-key header (NOT Bearer)
# Get it (self-hosted — inside your own panel): <your-dokploy-panel>/dashboard/settings/profile → API/CLI → Generate
DOKPLOY_API_URL=https://your-dokploy-domain.com/api
DOKPLOY_API_KEY=your_dokploy_api_key_here

# --- OPTIONAL: DNS AUTOMATION ---

# Hostinger DNS — auto adds A records for main domain + api-/dash-/site- Convex subdomains.
# Get it: https://hpanel.hostinger.com/profile/api   (Profile → API → Generate; shown once)
HOSTINGER_API_TOKEN=your_hostinger_token_here

# --- OPTIONAL: STUB DOMAINS (vars pre-registered, scripts not implemented yet) ---

# Cloudflare (future /sc-cf — DNS / Workers / Pages / R2)
# Get it: https://dash.cloudflare.com/profile/api-tokens   ("Edit zone DNS" template; scoped token, NOT the Global Key)
# Account ID: https://dash.cloudflare.com/?to=/:account/workers-and-pages → Account details
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Stripe (future /sc-stripe — products / webhooks / portal)
# Get it: https://dashboard.stripe.com/apikeys   (test mode: /test/apikeys)
# Webhook secret: https://dashboard.stripe.com/webhooks → endpoint → signing secret (whsec_)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# Resend (future /sc-resend — transactional email)
# Get it: https://resend.com/api-keys   (verify a FROM domain first at https://resend.com/domains)
# RESEND_API_KEY=
# RESEND_FROM_DOMAIN=

# Supabase (future /sc-supabase — alt backend)
# Get it: https://supabase.com/dashboard/account/tokens   (SUPABASE_ORG_ID = slug in /dashboard/org/<slug>)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_ORG_ID=

# --- OPTIONAL: ONLINE DEPLOY PATH (Vercel + Convex Cloud) ---

# Vercel (/sc-vercel — online frontend host)
# Get it: https://vercel.com/account/tokens   (scope = Full Account or the owning team; shown once)
VERCEL_TOKEN=your_vercel_token_here
# VERCEL_TEAM_ID=team_xxx   # only if project lives under a team

# Convex Cloud (/sc-convex-cloud — managed backend)
# Get it: https://dashboard.convex.dev/deployment/settings   (PROD deployment → General tab → Generate Production Deploy Key)
CONVEX_DEPLOY_KEY=prod:<deployment-name>|<token>
# CONVEX_DEPLOYMENT=          # local-dev marker only; leave blank in CI

# --- OPTIONAL: PRE-EXISTING CONVEX BACKEND (PLACEHOLDERS ONLY) ---
# Normally these are generated and saved automatically by sc-convex / sc-all.
# Only set these if you want to re-use a backend you deployed manually.

CONVEX_SELF_HOSTED_URL=https://<convex-api-domain>
CONVEX_SELF_HOSTED_ADMIN_KEY=<convex_admin_key>
NEXT_PUBLIC_CONVEX_URL=https://<convex-api-domain>
NEXT_PUBLIC_CONVEX_SITE_URL=https://<convex-site-domain>

# --- OPTIONAL: TAILSCALE SYNC (/sc-sync — rsync gitignored files vps <-> local) ---
# No login/token — addresses come from `tailscale status` / `tailscale ip -4`.

# Which machine THIS process runs on. Set once per machine, never the same on both.
# SYNC_ROLE=local
# SYNC_ROLE=vps

# Tailscale MagicDNS alias or 100.x IP for each side of the pair.
# SYNC_VPS_TS_ADDR=your-vps
# SYNC_LOCAL_TS_ADDR=your-laptop

# Optional — only set if they differ from the defaults (current OS user /
# this repo's own `git rev-parse --show-toplevel` path).
# SYNC_REMOTE_USER=your_remote_username
# SYNC_REMOTE_PATH=/path/to/repo/on/other/machine

# --- OPTIONAL: CLERK (ONLY if your app explicitly uses Clerk) ---
# By default sc-* uses @convex-dev/auth. Use Clerk MCP for Clerk-specific projects.
# Get it: https://dashboard.clerk.com/~/api-keys   (~ = last-active instance; dev=*_test_, prod=*_live_)

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_<clerk_publishable_key>
CLERK_SECRET_KEY=sk_live_<clerk_secret_key>
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://<clerk-issuer-domain>
